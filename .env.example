AI_MEDIA_OS_ENVIRONMENT=development
AI_MEDIA_OS_APP_NAME=AI Media OS
AI_MEDIA_OS_LOG_LEVEL=INFO
AI_MEDIA_OS_LOG_FORMAT=json
AI_MEDIA_OS_DATABASE_URL=sqlite:///data/database/ai_media_os.db
AI_MEDIA_OS_DATA_DIR=data
AI_MEDIA_OS_CACHE_DIR=data/cache
AI_MEDIA_OS_PROJECTS_DIR=data/projects
AI_MEDIA_OS_LOGS_DIR=data/logs
AI_MEDIA_OS_QUEUE_LEASE_SECONDS=300
AI_MEDIA_OS_QUEUE_RETRY_BASE_DELAY_SECONDS=60
AI_MEDIA_OS_QUEUE_RETRY_MAX_DELAY_SECONDS=3600
AI_MEDIA_OS_QUEUE_RESOURCE_LIMITS='{"CPU_LIGHT":3,"CPU_HEAVY":2,"GPU_LIGHT":1,"GPU_HEAVY":1,"NETWORK":3,"MANUAL":0}'
AI_MEDIA_OS_WORKFLOW_MAX_SCRIPT_REVISIONS=1
AI_MEDIA_OS_RESEARCH_MAX_SOURCE_BYTES=1000000
AI_MEDIA_OS_RESEARCH_ALLOWED_TEXT_EXTENSIONS='[".txt",".md"]'
AI_MEDIA_OS_RESEARCH_DUPLICATE_CONTENT_WARNING_THRESHOLD=0.5
AI_MEDIA_OS_RESEARCH_MIN_PRIMARY_SOURCES=1
AI_MEDIA_OS_RESEARCH_MAX_SOURCE_CONCENTRATION=0.6
AI_MEDIA_OS_RESEARCH_REQUIRE_PRIMARY_FOR_CRITICAL=true
AI_MEDIA_OS_DASHBOARD_ENABLED=true
AI_MEDIA_OS_DASHBOARD_HOST=127.0.0.1
AI_MEDIA_OS_DASHBOARD_PORT=8000
AI_MEDIA_OS_DASHBOARD_POLL_SECONDS=8
AI_MEDIA_OS_DASHBOARD_TIMEZONE=Asia/Kolkata
AI_MEDIA_OS_DASHBOARD_CSRF_SECRET=replace-with-local-random-dashboard-secret
AI_MEDIA_OS_IMAGE_DEFAULT_WIDTH=1280
AI_MEDIA_OS_IMAGE_DEFAULT_HEIGHT=720
AI_MEDIA_OS_IMAGE_DEFAULT_PROVIDER=fake_image
AI_MEDIA_OS_IMAGE_ALLOWED_EXTENSIONS='[".png",".jpg",".jpeg"]'
AI_MEDIA_OS_VOICE_DEFAULT_PROVIDER=fake_voice
AI_MEDIA_OS_VOICE_DEFAULT_NAME=ai-future-neutral
AI_MEDIA_OS_VOICE_DEFAULT_LANGUAGE=en
AI_MEDIA_OS_VOICE_ALLOWED_EXTENSIONS='[".wav",".mp3"]'
AI_MEDIA_OS_ASSET_MAX_FILE_BYTES=20000000
AI_MEDIA_OS_FFMPEG_PATH=ffmpeg
AI_MEDIA_OS_FFPROBE_PATH=ffprobe
AI_MEDIA_OS_RENDER_DEFAULT_WIDTH=1280
AI_MEDIA_OS_RENDER_DEFAULT_HEIGHT=720
AI_MEDIA_OS_RENDER_DEFAULT_FPS=24
AI_MEDIA_OS_RENDER_DEFAULT_FORMAT=mp4
AI_MEDIA_OS_RENDER_DEFAULT_PROVIDER=local_ffmpeg
AI_MEDIA_OS_RENDER_MAX_SECONDS=3600
AI_MEDIA_OS_RENDER_DEFAULT_BACKGROUND_COLOR=black
AI_MEDIA_OS_RENDER_ALLOW_PENDING_ASSETS=true
AI_MEDIA_OS_METADATA_TITLE_COUNT=5
AI_MEDIA_OS_METADATA_TAG_COUNT=12
AI_MEDIA_OS_METADATA_DEFAULT_PROVIDER=fake_metadata
AI_MEDIA_OS_THUMBNAIL_DEFAULT_WIDTH=1280
AI_MEDIA_OS_THUMBNAIL_DEFAULT_HEIGHT=720
AI_MEDIA_OS_THUMBNAIL_DEFAULT_PROVIDER=fake_thumbnail
AI_MEDIA_OS_THUMBNAIL_ALLOWED_EXTENSIONS='[".png",".jpg",".jpeg",".webp"]'

AI_MEDIA_OS_SAFETY_RULE_VERSION=safety-v1
AI_MEDIA_OS_SAFETY_SIMILARITY_THRESHOLD=0.88
